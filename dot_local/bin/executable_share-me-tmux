#!/usr/bin/env bash

# Load the token securely
CLOUDFLARED_TOKEN=$(cat /home/mandrake/.secrets/cloudflared_token)

if tmux has-session -t shared 2>/dev/null; then
    echo "Tmux session 'shared' already exists."
else
    echo "Creating new tmux session 'shared'..."
    tmux new-session -d -s shared
    tmux rename-window -t shared:0 "workspace"
    
    # Start ttyd sharing this tmux session (Removed basic auth since CF Access handles SSO)
    tmux new-window -d -t shared -n "ttyd" "ttyd -W -p 7681 tmux attach -t shared"
    
    # Start zellij terminal IDE setup over ttyd
    tmux new-window -d -t shared -n "zellij-ide" "ttyd -W -p 7682 zellij --layout /home/mandrake/.config/zellij/layouts/ide.kdl"
    
    # Start pi-webui for mobile-friendly agent interaction
    tmux new-window -d -t shared -n "pi-webui" "npx -y @khimaros/pi-webui --listen 127.0.0.1:8787"

    # Start Pico for alternative mobile interaction
    tmux new-window -d -t shared -n "pico" "pico-app --host 127.0.0.1 --port 3141 --no-open"

    # Start pi-web (ravshansbox)
    tmux new-window -d -t shared -n "pi-web" "npx -y pi-web@latest --port 8192 --host 127.0.0.1"

    # Start oh-my-pi with webui
    tmux new-window -d -t shared -n "omp-webui" "ttyd -W -p 3848 omp --provider google-vertex --model gemini-3.1-pro-preview-customtools --smol gemini-3.1-pro-preview-customtools"
    
    # Start wgnr-pi
    tmux new-window -d -t shared -n "wgnr-pi" "WGPI_PORT=4815 wgnr-pi"

    # Start pi-dashboard
    tmux new-window -d -t shared -n "pi-dashboard" "cd /home/mandrake/pi-dashboard && PI_DASH_PORT=7777 npm start"

    # Start the custom system gateway
    tmux new-window -d -t shared -n "gateway" "python3 -m http.server 8888 --directory /home/mandrake/gateway"

    # Start the persistent Cloudflare tunnel using the secure token
    tmux new-window -d -t shared -n "cloudflared" "cloudflared tunnel run --token ${CLOUDFLARED_TOKEN}"

    # Focus the first window so when attached it shows the shell instead of the tunnel
    tmux select-window -t shared:0
    
    echo "Tmux session 'shared' started with the persistent Cloudflare tunnel!"
fi

echo "Attaching to 'shared' session locally..."
tmux attach -t shared