#!/usr/bin/env bash

TYPE=$1
PORT=$2
GIST_ID="0ad758c2fa3968b710f59f89361e64b2"

cloudflared tunnel --url "http://localhost:${PORT}" 2>&1 | while read -r line; do
    echo "$line"
    if [[ "$line" == *"trycloudflare.com"* ]]; then
        URL=$(echo "$line" | grep -oE 'https://[a-zA-Z0-9-]+\.trycloudflare\.com')
        if [ -n "$URL" ]; then
            echo "$URL" > "/tmp/${TYPE}_url.txt"
            
            echo "Cloudflare Tunnels Updated: $(date)" > /tmp/gist_update.txt
            echo "" >> /tmp/gist_update.txt
            if [ -f /tmp/ttyd_url.txt ]; then
                echo "TTYD Tunnel (Raw Shell): $(cat /tmp/ttyd_url.txt)" >> /tmp/gist_update.txt
            fi
            if [ -f /tmp/webui_url.txt ]; then
                echo "Zellij WebUI (Native UI): $(cat /tmp/webui_url.txt)" >> /tmp/gist_update.txt
            fi
            
            gh gist edit "$GIST_ID" -a /tmp/gist_update.txt >/dev/null 2>&1
        fi
    fi
done